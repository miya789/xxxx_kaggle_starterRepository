# ============================================================
#  RunPod / データDL 用 鍵ファイル 雛形
#  使い方: これをリポジトリ直下に `.runpod.env` としてコピーし、値を入れる。
#    cp tools/runpod/.runpod.env.example .runpod.env
#  ★ .runpod.env は必ず .gitignore（*.env / .runpod.env）。生値をcommit/チャット/ログに出さない。
#  使うとき:  source .runpod.env
# ============================================================

# --- 必須: RunPod 操作（runpodctl / runpod_ops.py が読む。ローカルに置く唯一の鍵） ---
export RUNPOD_API_KEY=""          # runpod.io/console/user/settings → API Keys → Create (Read/Write)
export RUNPOD_VOLUME_ID=""        # Network Volume 作成後に設定（疎通テストでは空でOK）

# --- pod に渡す鍵は基本 RunPod Secrets に登録して参照する（ここは空のままでよい） ---
#   下を空にして RunPod Secrets(GH_TOKEN等) に入れると、生値がローカルに残らず最も安全。
#   ローカルで clone 検証したい時だけ一時的に GH_TOKEN を入れる、等の用途。
export GIT_REPO="github.com/<user>/<repo>.git"   # private repo（cloneする場合）
export GH_TOKEN=""                # GitHub Fine-grained PAT（対象repoのみ / Contents:Read-only）
export HF_TOKEN=""                # huggingface.co Access Token (Read scope)
export KAGGLE_USERNAME=""         # kaggle.json の "username"
export KAGGLE_KEY=""              # kaggle.json の "key"
